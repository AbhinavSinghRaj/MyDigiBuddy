# ── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
# Neon / Supabase / Render PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/admind?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Google Ads OAuth ──────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URI=http://localhost:4000/api/v1/connections/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=   # From Google Ads API Center

# ── Meta Ads OAuth ────────────────────────────────────────────
# Create app at https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/v1/connections/meta/callback

# ── LLM ───────────────────────────────────────────────────────
# Use one of the three — the backend tries in this order: Anthropic → OpenAI → Groq
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Redis (BullMQ background jobs) ────────────────────────────
REDIS_URL=redis://localhost:6379
