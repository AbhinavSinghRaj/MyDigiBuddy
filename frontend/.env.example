# Next.js public URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# NextAuth (Auth.js)
NEXTAUTH_SECRET=change_me_to_a_random_32_char_string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for user login — separate from Ads OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta OAuth (for user login — separate from Ads OAuth)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
